{
  "name": "fizz-layout",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "dev": "pnpm -C play run dev",
    "build": "rimraf dist && pnpm build:turbo --force",
    "build:turbo": "turbo run build:layout build:locale build:css build:release lint:package",
    "build:serial": "pnpm build:layout && pnpm build:locale && pnpm build:css && pnpm build:release && pnpm lint:package",
    "build:layout": "pnpm -C packages/layout run build",
    "build:locale": "pnpm -C packages/locale run build",
    "build:css": "node scripts/build-css.mjs",
    "build:release": "node scripts/build-release.mjs",
    "play:build": "pnpm -C play run build",
    "play:preview": "pnpm -C play run preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:package": "publint ./dist",
    "test": "vitest",
    "inspector": "pnpx node-modules-inspector"
  },
  "dependencies": {
    "@fizz-layout/components": "workspace:*",
    "@fizz-layout/core": "workspace:*",
    "@fizz-layout/hooks": "workspace:*",
    "@fizz-layout/locale": "workspace:*",
    "@iconify/vue": "catalog:",
    "@vueuse/core": "catalog:",
    "@vueuse/integrations": "catalog:",
    "element-plus": "catalog:",
    "shiki": "catalog:",
    "sortablejs": "catalog:",
    "vue": "catalog:",
    "vue-i18n": "catalog:",
    "vue-router": "catalog:"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:",
    "@iconify-json/carbon": "catalog:",
    "@types/node": "catalog:",
    "@types/sortablejs": "catalog:",
    "@vitejs/plugin-vue": "catalog:",
    "@vue/tsconfig": "catalog:",
    "eslint": "catalog:",
    "eslint-plugin-format": "catalog:",
    "happy-dom": "catalog:",
    "publint": "catalog:",
    "rimraf": "catalog:",
    "sass-embedded": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "unplugin-icons": "catalog:",
    "vite": "catalog:",
    "vite-plugin-dts": "catalog:",
    "vite-plugin-vue-devtools": "catalog:",
    "vitest": "catalog:",
    "vue-tsc": "catalog:"
  }
}
